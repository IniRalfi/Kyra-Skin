{
  "name": "kyra-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && bun run dev",
    "dev:web": "cd backend-web && php artisan serve",
    "dev:ai": "cd backend-ai && venv/bin/fastapi dev main.py --port 8001",
    "dev": "concurrently -c \"cyan,magenta,yellow\" -n \"FRONTEND,WEB,AI\" \"bun run dev:frontend\" \"bun run dev:web\" \"bun run dev:ai\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.2.1"
  },
  "module": "index.ts",
  "type": "module",
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "framer-motion": "^12.36.0"
  }
}
