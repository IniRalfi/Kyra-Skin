{
  "name": "kyra-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "bun --cwd frontend run dev",
    "dev:web": "cd backend-web && php artisan serve",
    "dev:ai": "cd backend-ai && fastapi dev main.py",
    "dev": "bun run dev:frontend & bun run dev:web & bun run dev:ai",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
